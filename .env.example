# ─────────────────────────────────────────────────────────────────────
# Environment variables — copy this file to `.env` and fill in values.
#
#   cp .env.example .env
#
# ⚠️ IMPORTANT: this site is a STATIC EXPORT. All of these values are
# baked into the HTML/JS at BUILD time. Changing .env does nothing until
# you run `npm run build` again (or push, if Cloudflare Pages builds for
# you — set the same variables in the Pages project settings).
#
# Everything here is OPTIONAL. With all values empty the site still
# builds and runs; each integration just switches itself off gracefully.
# ─────────────────────────────────────────────────────────────────────

# The live domain, no trailing slash. Used for the canonical URL,
# Open Graph tags, sitemap.xml and robots.txt.
# Empty → falls back to https://example.com (fine for local dev,
# WRONG for production — always set this before launching a client).
NEXT_PUBLIC_SITE_URL=

# Contact form via https://web3forms.com — free, built for static sites,
# no backend needed. Sign up with the CLIENT's email (that's where
# messages get delivered) and paste the Access Key here.
# Empty → the form renders in a clearly-labeled disabled/demo state.
# Note: Web3Forms access keys are designed to be public; exposing this
# in the built site is expected and safe.
NEXT_PUBLIC_WEB3FORMS_KEY=

# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
# (GA4 Admin → Data Streams → your stream → Measurement ID).
# Empty → the analytics script is not injected at all.
NEXT_PUBLIC_GA_ID=
